local tool=script.Parent
local plr=game.Players.LocalPlayer
local rs=game:GetService("ReplicatedStorage")
local net=rs:WaitForChild("Modules"):WaitForChild("Net")
local reghit=net:WaitForChild("RE/RegisterHit")
local regatk=net:WaitForChild("RE/RegisterAttack")
local running=false
local function getnpc()
	local char=plr.Character
	if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local nearest=nil
	local dist=math.huge
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") then
			local h=v:FindFirstChildOfClass("Humanoid")
			if h and h.Health>0 then
				if not game.Players:GetPlayerFromCharacter(v) then
					local part=v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
					if part then
						local d=(part.Position-hrp.Position).Magnitude
						if d<dist then
							dist=d
							nearest=part
						end
					end
				end
			end
		end
	end
	return nearest
end
tool.Equipped:Connect(function()
	running=true
	while running do
		local target=getnpc()
		if target then
			for i=1,100 do
				regatk:FireServer(0.5)
				reghit:FireServer(target,{}, "5031e87d")
			end
		end
		task.wait()
	end
end)
tool.Unequipped:Connect(function()
	running=false
end)
