local plr=game.Players.LocalPlayer
local rs=game:GetService("ReplicatedStorage")
local net=rs:WaitForChild("Modules"):WaitForChild("Net")
local reghit=net:WaitForChild("RE/RegisterHit")
local regatk=net:WaitForChild("RE/RegisterAttack")
local running=false
local curtool=nil
local function getnpc()
	local char=plr.Character
	if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local nearest=nil
	local dist=math.huge
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model") then
			local h=v:FindFirstChildOfClass("Humanoid")
			if h and h.Health>0 then
				if not game.Players:GetPlayerFromCharacter(v) then
					local part=v:FindFirstChild("HumanoidRootPart") or v:FindFirstChildWhichIsA("BasePart")
					if part then
						local d=(part.Position-hrp.Position).Magnitude
						if d<dist then
							dist=d
							nearest=part
						end
					end
				end
			end
		end
	end
	return nearest
end
local function start()
	if running then return end
	running=true
	task.spawn(function()
		while running do
			local target=getnpc()
			if target then
				for i=1,100 do
					regatk:FireServer(0.5)
					reghit:FireServer(target,{}, "5031e87d")
				end
			end
			task.wait()
		end
	end)
end
local function stop()
	running=false
end
local function hooktool(t)
	if not t:IsA("Tool") then return end
	t.Equipped:Connect(function()
		curtool=t
		start()
	end)
	t.Unequipped:Connect(function()
		if curtool==t then
			curtool=nil
			stop()
		end
	end)
end
local function setupchar(char)
	for _,v in pairs(char:GetChildren()) do
		hooktool(v)
	end
	char.ChildAdded:Connect(function(v)
		hooktool(v)
	end)
end
if plr.Character then
	setupchar(plr.Character)
end
plr.CharacterAdded:Connect(setupchar)
